#!/usr/bin/env bash
#
# gbrain-patchkit — standalone source-patch orchestrator for gbrain
#
# Patches gbrain's hardcoded Anthropic model IDs into env-driven overrides so
# you can point them at MiniMax, a self-hosted litellm gateway, or any other
# Anthropic-compatible endpoint. Patches auto-reapply after `gbrain upgrade`.
#
# Layout:
#   ~/.gbrain-patchkit/bin/gbrain-patchkit     (this tool)
#   ~/.gbrain-patchkit/substitutions.json      (editable patch rules)
#   ~/.gbrain-patchkit/env.sh                  (your keys + models, sourced from ~/.zshrc)
#   ~/.gbrain-patchkit/apply.log               (append-only audit log)
#
# Commands:
#   onboard            interactive setup (keys, URL, models, env + hook + preload)
#   install            non-interactive: write default config + shell hook only
#   migrate            switch from source-patch to runtime SDK override (idempotent)
#   upgrade            stash → git pull ~/gbrain → bun install → pop → post-upgrade
#   doctor             verify env + preload + patch state
#   apply [--quiet]    apply every enabled substitution (legacy source-patch path)
#   check              show status of every substitution
#   revert             undo every substitution
#   edit               open substitutions.json in $EDITOR
#   env                open env.sh in $EDITOR
#   locate             print the resolved gbrain source directory
#   update             git pull inside the install dir
#   uninstall          remove shell hook (leaves files for you to rm)
#   help               show this help

set -euo pipefail

PATCHKIT_HOME="${GBRAIN_PATCHKIT_HOME:-$HOME/.gbrain-patchkit}"
CONFIG="$PATCHKIT_HOME/substitutions.json"
CONFIG_DEFAULT="$PATCHKIT_HOME/substitutions.default.json"
ENV_FILE="$PATCHKIT_HOME/env.sh"
LOG="$PATCHKIT_HOME/apply.log"

QUIET=0
FLAGS=()
for arg in "$@"; do
  case "$arg" in
    --quiet) QUIET=1 ;;
    *)       FLAGS+=("$arg") ;;
  esac
done

say()  { [ "$QUIET" -eq 1 ] || printf '%s\n' "$*"; }
info() { printf '%s\n' "$*"; }
err()  { printf '%s\n' "$*" >&2; }

# --- locate gbrain source ----------------------------------------------------

resolve_gbrain_src() {
  local override="${GBRAIN_SOURCE_DIR:-}"
  if [ -n "$override" ]; then
    if [ -f "$override/package.json" ] && grep -q '"name": "gbrain"' "$override/package.json"; then
      printf '%s\n' "$override"; return
    fi
    err "GBRAIN_SOURCE_DIR set to $override but not a gbrain source tree"
    exit 1
  fi
  if ! command -v gbrain >/dev/null 2>&1; then
    err "gbrain not on PATH. Install gbrain first, or set GBRAIN_SOURCE_DIR=/path/to/gbrain."
    exit 1
  fi
  local bin real pkg_dir
  bin="$(command -v gbrain)"
  real="$(python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$bin")"
  pkg_dir="$(dirname "$real")"
  while [ "$pkg_dir" != "/" ] && [ ! -f "$pkg_dir/package.json" ]; do
    pkg_dir="$(dirname "$pkg_dir")"
  done
  if [ ! -f "$pkg_dir/package.json" ] || ! grep -q '"name": "gbrain"' "$pkg_dir/package.json"; then
    err "resolved path does not look like a gbrain source tree: $pkg_dir"
    err "set GBRAIN_SOURCE_DIR=/path/to/gbrain explicitly"
    exit 1
  fi
  printf '%s\n' "$pkg_dir"
}

# --- substitution engine (python3: config parsing + file I/O) -----------------

run_engine() {
  python3 - "$@" <<'PY'
import json, pathlib, sys, datetime

mode, src_dir, config_path, log_path, quiet_flag = sys.argv[1:6]
quiet = quiet_flag == "1"

def log(msg):
    try:
        with open(log_path, "a") as f:
            ts = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
            f.write(f"{ts} [{mode}] {msg}\n")
    except Exception:
        pass

def say(msg):
    if not quiet:
        print(msg)

try:
    cfg = json.loads(pathlib.Path(config_path).read_text())
except FileNotFoundError:
    print(f"no config at {config_path}. Run: gbrain-patchkit onboard", file=sys.stderr)
    sys.exit(1)

substitutions = [s for s in cfg.get("substitutions", []) if s.get("enabled", True)]
if not substitutions:
    say("(no enabled substitutions)")
    sys.exit(0)

src = pathlib.Path(src_dir)
say(f"[patchkit] source: {src}")
if mode == "check":
    say(f"[patchkit] config: {config_path}")

exit_rc = 0
for s in substitutions:
    rel = s["file"]; name = s.get("name", rel)
    find_s = s["find"]; replace_s = s["replace"]; marker = s["marker"]
    p = src / rel

    if not p.exists():
        say(f"  MISSING      {rel}  ({name})")
        log(f"MISSING {rel}"); exit_rc = 2; continue

    text = p.read_text()
    has_marker = marker in text
    has_find = find_s in text
    has_replace = replace_s in text

    if has_marker and has_replace:       status = "patched"
    elif (not has_marker) and has_find:  status = "unpatched"
    else:                                status = "drifted"

    if mode == "check":
        say(f"  {status:<12} {rel}  ({name})"); continue

    if mode == "apply":
        if status == "patched":
            say(f"  skip         {rel}  ({name})"); log(f"skip {rel}"); continue
        if status == "drifted":
            say(f"  DRIFT        {rel}  ({name}) — neither form found; inspect manually")
            log(f"DRIFT {rel}"); exit_rc = 3; continue
        count = text.count(find_s)
        if count != 1:
            say(f"  AMBIGUOUS    {rel}  ({name}) — expected 1 match, found {count}")
            log(f"AMBIGUOUS {rel} matches={count}"); exit_rc = 3; continue
        tmp = p.with_suffix(p.suffix + ".patchkit.tmp")
        tmp.write_text(text.replace(find_s, replace_s)); tmp.replace(p)
        say(f"  applied      {rel}  ({name})"); log(f"applied {rel}"); continue

    if mode == "revert":
        if status == "unpatched":
            say(f"  skip         {rel}  ({name})"); log(f"skip {rel}"); continue
        if status == "drifted":
            say(f"  DRIFT        {rel}  ({name}) — cannot revert cleanly")
            log(f"DRIFT {rel}"); exit_rc = 3; continue
        tmp = p.with_suffix(p.suffix + ".patchkit.tmp")
        tmp.write_text(text.replace(replace_s, find_s)); tmp.replace(p)
        say(f"  reverted     {rel}  ({name})"); log(f"reverted {rel}"); continue

    print(f"unknown mode: {mode}", file=sys.stderr); sys.exit(2)

sys.exit(exit_rc)
PY
}

# --- helpers -----------------------------------------------------------------

ensure_config() {
  if [ ! -f "$CONFIG" ]; then
    if [ -f "$CONFIG_DEFAULT" ]; then
      cp "$CONFIG_DEFAULT" "$CONFIG"
      say "[patchkit] seeded config from $CONFIG_DEFAULT"
    else
      err "no config at $CONFIG and no default to seed from. Run: gbrain-patchkit onboard"
      exit 1
    fi
  fi
}

pick_rc_file() {
  if [ -f "$HOME/.zshrc" ]; then   printf '%s\n' "$HOME/.zshrc"
  elif [ -f "$HOME/.bashrc" ]; then printf '%s\n' "$HOME/.bashrc"
  else                              printf '%s\n' "$HOME/.profile"
  fi
}

install_shell_hook() {
  local rc_file; rc_file="$(pick_rc_file)"
  local start="# >>> gbrain-patchkit >>>"
  local end="# <<< gbrain-patchkit <<<"
  # Sentinel present in the current hook version but not in older hooks — lets
  # us detect stale blocks and rewrite them in place. Bump on any hook change.
  local version_sentinel='gbrain-patchkit hook v2 (scoped env)'

  # v3 sentinel — bumped when the wrapper switched from `command gbrain` to
  # `bun --preload` (BUN_PRELOAD env var is not respected by Bun 1.3.x; the
  # CLI flag is the only reliable preload mechanism).
  version_sentinel='gbrain-patchkit hook v3 (runtime override)'

  local has_block=0 is_current=0
  if grep -qF "$start" "$rc_file" 2>/dev/null; then
    has_block=1
    if awk -v s="$start" -v e="$end" -v v="$version_sentinel" '
      $0 ~ s {inside=1; next}
      $0 ~ e {inside=0; next}
      inside && index($0, v) {found=1}
      END {exit found ? 0 : 1}
    ' "$rc_file" 2>/dev/null; then
      is_current=1
    fi
  fi

  if [ "$has_block" = "1" ] && [ "$is_current" = "1" ]; then
    say "[install] shell hook already present and current in $rc_file"
    return
  fi

  if [ "$has_block" = "1" ] && [ "$is_current" = "0" ]; then
    # Old hook — strip it before writing the new one so we don't duplicate.
    local tmp; tmp="$(mktemp)"
    python3 - "$rc_file" "$tmp" "$start" "$end" <<'PY'
import pathlib, sys
src, dst, start, end = sys.argv[1:5]
text = pathlib.Path(src).read_text()
i = text.find(start); j = text.find(end, i+1)
if i == -1 or j == -1:
    pathlib.Path(dst).write_text(text); sys.exit(0)
out = text[:i].rstrip("\n") + "\n" + text[j+len(end):].lstrip("\n")
pathlib.Path(dst).write_text(out)
PY
    mv "$tmp" "$rc_file"
    say "[install] removed stale hook block from $rc_file"
  fi

  cat >> "$rc_file" <<EOF

$start
# gbrain-patchkit hook v3 (runtime override) — do not edit this line; it marks the hook version.
# Added by gbrain-patchkit. Remove this block between the markers to uninstall.
# Keys + GBRAIN_ENTRY/GBRAIN_OVERRIDE_JS live in ~/.gbrain-patchkit/env.sh and
# are sourced ONLY inside the gbrain function below — they never leak into the
# parent shell or sibling tools (Claude Code, codex, etc.).
#
# The wrapper invokes \`bun --preload <override.js> <cli.ts>\` directly. Bun's
# BUN_PRELOAD env var is not respected (1.3.x); the --preload flag is the only
# reliable hook point. Falling back to \`command gbrain\` if env vars are missing
# (which means the SDK runs unwrapped — fix with: gbrain-patchkit migrate).
export PATH="\$HOME/.gbrain-patchkit/bin:\$PATH"
gbrain() {
  local rc
  (
    [ -f "\$HOME/.gbrain-patchkit/env.sh" ] && . "\$HOME/.gbrain-patchkit/env.sh"
    if [ -n "\${GBRAIN_ENTRY:-}" ] && [ -f "\$GBRAIN_ENTRY" ] \\
       && [ -n "\${GBRAIN_OVERRIDE_JS:-}" ] && [ -f "\$GBRAIN_OVERRIDE_JS" ] \\
       && command -v bun >/dev/null 2>&1; then
      exec bun --preload "\$GBRAIN_OVERRIDE_JS" "\$GBRAIN_ENTRY" "\$@"
    fi
    # Fallback: native gbrain bin without preload. Override won't engage; run
    # \`gbrain-patchkit migrate\` to set GBRAIN_ENTRY/GBRAIN_OVERRIDE_JS.
    exec command gbrain "\$@"
  )
  rc=\$?
  return \$rc
}
$end
EOF
  if [ "$has_block" = "1" ]; then
    say "[install] upgraded hook in $rc_file — run: source $rc_file"
  else
    say "[install] added hook to $rc_file — run: source $rc_file"
  fi
}

remove_shell_hook() {
  local rc_file; rc_file="$(pick_rc_file)"
  if ! grep -qF "# >>> gbrain-patchkit >>>" "$rc_file" 2>/dev/null; then
    say "[uninstall] no hook found in $rc_file"
    return
  fi
  local tmp; tmp="$(mktemp)"
  python3 - "$rc_file" "$tmp" <<'PY'
import pathlib, sys
src, dst = sys.argv[1], sys.argv[2]
text = pathlib.Path(src).read_text()
start, end = "# >>> gbrain-patchkit >>>", "# <<< gbrain-patchkit <<<"
i = text.find(start)
j = text.find(end, i+1)
if i == -1 or j == -1:
    pathlib.Path(dst).write_text(text); sys.exit(0)
# Also strip the blank line before the block if present
out = text[:i].rstrip("\n") + "\n" + text[j+len(end):].lstrip("\n")
pathlib.Path(dst).write_text(out)
PY
  mv "$tmp" "$rc_file"
  say "[uninstall] removed hook block from $rc_file"
}

mask() {
  # Mask a secret: show last 4 chars preceded by ****.
  local v="$1"
  local n=${#v}
  if [ "$n" -le 8 ]; then printf '(%d chars)\n' "$n"; return; fi
  printf '****%s\n' "${v: -4}"
}

prompt() {
  # prompt "Question" "default" varname
  local q="$1" def="$2" var="$3" ans
  if [ -n "$def" ]; then
    read -r -p "  $q [$def]: " ans || true
    printf -v "$var" '%s' "${ans:-$def}"
  else
    read -r -p "  $q: " ans || true
    printf -v "$var" '%s' "$ans"
  fi
}

prompt_secret() {
  # prompt_secret "Question" varname
  local q="$1" var="$2" ans
  read -r -s -p "  $q: " ans || true
  echo
  printf -v "$var" '%s' "$ans"
}

PRELOAD_FILE="$PATCHKIT_HOME/anthropic-override.js"

# Resolve gbrain's actual entry script (real path, following symlinks).
# bun-link installs ~/.bun/bin/gbrain as a symlink chain that ends at the
# user's gbrain checkout's src/cli.ts. The runtime-override wrapper invokes
# bun --preload directly against this entry, bypassing the bun-link bin.
resolve_gbrain_entry() {
  if ! command -v gbrain >/dev/null 2>&1; then return 1; fi
  local bin real
  bin="$(command -v gbrain)"
  real="$(python3 -c 'import os,sys;print(os.path.realpath(sys.argv[1]))' "$bin" 2>/dev/null || true)"
  [ -n "$real" ] && [ -f "$real" ] || return 1
  printf '%s\n' "$real"
}

# Build the runtime-override export block for env.sh. Three vars:
#   GBRAIN_SOURCE_DIR — anchor for the preload's createRequire (the preload
#                       lives in ~/.gbrain-patchkit/ which has no node_modules)
#   GBRAIN_ENTRY      — absolute path to gbrain's cli.ts; the shell-function
#                       wrapper invokes `bun --preload <override> $GBRAIN_ENTRY`
#                       so Bun honors the preload (its BUN_PRELOAD env var is
#                       not respected; --preload flag is the only path that
#                       works on every invocation in Bun 1.3.x)
#   GBRAIN_OVERRIDE_JS — absolute path to the preload module (used by the
#                       wrapper's --preload argument).
emit_preload_block() {
  local src="$1"     # absolute path to gbrain source dir, may be empty
  local entry="$2"   # absolute path to gbrain's cli.ts entry, may be empty
  printf '\n# Anthropic SDK runtime override (replaces source-patch mechanism).\n'
  printf '# Loaded via `bun --preload` in the gbrain shell-function wrapper;\n'
  printf '# intercepts Messages.create to swap models. ~/gbrain stays untouched.\n'
  if [ -n "$src" ]; then
    printf 'export GBRAIN_SOURCE_DIR=%q\n' "$src"
  else
    printf '# export GBRAIN_SOURCE_DIR=/path/to/gbrain   # (auto-detect failed; set manually)\n'
  fi
  if [ -n "$entry" ]; then
    printf 'export GBRAIN_ENTRY=%q\n' "$entry"
  else
    printf '# export GBRAIN_ENTRY=/path/to/gbrain/src/cli.ts   # (auto-detect failed; set manually)\n'
  fi
  printf 'export GBRAIN_OVERRIDE_JS=%q\n' "$PRELOAD_FILE"
}

write_env_file() {
  # Args passed as VAR=VAL pairs, one per line in the env file.
  local openai="$1" minimax="$2" minimax_base="$3" exp_model="$4" sub_model="$5"
  local src="" entry=""
  src="$(resolve_gbrain_src 2>/dev/null || true)"
  entry="$(resolve_gbrain_entry 2>/dev/null || true)"
  umask 077
  cat > "$ENV_FILE" <<EOF
# ~/.gbrain-patchkit/env.sh — generated by gbrain-patchkit onboard
# Sourced from your shell rc via the patchkit install block.
# Safe to hand-edit. Re-run \`gbrain-patchkit onboard --reconfigure\` to rewrite.

EOF
  [ -n "$openai" ]       && printf 'export OPENAI_API_KEY=%q\n'           "$openai"       >> "$ENV_FILE"
  [ -n "$minimax" ]      && printf 'export ANTHROPIC_API_KEY=%q\n'        "$minimax"      >> "$ENV_FILE"
  [ -n "$minimax_base" ] && printf 'export ANTHROPIC_BASE_URL=%q\n'       "$minimax_base" >> "$ENV_FILE"
  [ -n "$exp_model" ]    && printf 'export GBRAIN_EXPANSION_MODEL=%q\n'   "$exp_model"    >> "$ENV_FILE"
  [ -n "$sub_model" ]    && printf 'export GBRAIN_SUBAGENT_MODEL=%q\n'    "$sub_model"    >> "$ENV_FILE"
  emit_preload_block "$src" "$entry" >> "$ENV_FILE"
  chmod 600 "$ENV_FILE"
}

# Append GBRAIN_SOURCE_DIR + GBRAIN_ENTRY + GBRAIN_OVERRIDE_JS exports to an
# existing env.sh if they aren't there yet. Used by `migrate` so existing
# installs gain the runtime override without losing their hand-edited keys.
ensure_preload_export() {
  local src="$1"
  local entry=""
  entry="$(resolve_gbrain_entry 2>/dev/null || true)"

  if [ ! -f "$ENV_FILE" ]; then
    umask 077
    cat > "$ENV_FILE" <<EOF
# ~/.gbrain-patchkit/env.sh — created by gbrain-patchkit migrate
# Sourced from your shell rc via the patchkit install block.

EOF
    chmod 600 "$ENV_FILE"
  fi

  local has_source_dir=0 has_entry=0 has_override=0
  grep -qE '^[[:space:]]*export[[:space:]]+GBRAIN_SOURCE_DIR='  "$ENV_FILE" 2>/dev/null && has_source_dir=1
  grep -qE '^[[:space:]]*export[[:space:]]+GBRAIN_ENTRY='       "$ENV_FILE" 2>/dev/null && has_entry=1
  grep -qE '^[[:space:]]*export[[:space:]]+GBRAIN_OVERRIDE_JS=' "$ENV_FILE" 2>/dev/null && has_override=1

  if [ "$has_source_dir" = "1" ] && [ "$has_entry" = "1" ] && [ "$has_override" = "1" ]; then
    say "[migrate] runtime-override exports already configured in $ENV_FILE"
    return
  fi

  {
    printf '\n# --- runtime override (added by gbrain-patchkit migrate) ---\n'
    [ "$has_source_dir" = "0" ] && [ -n "$src" ]   && printf 'export GBRAIN_SOURCE_DIR=%q\n' "$src"
    [ "$has_entry"      = "0" ] && [ -n "$entry" ] && printf 'export GBRAIN_ENTRY=%q\n'      "$entry"
    [ "$has_override"   = "0" ]                    && printf 'export GBRAIN_OVERRIDE_JS=%q\n' "$PRELOAD_FILE"
    # Cleanup: older patchkit versions wrote a no-op BUN_PRELOAD line. Leave any
    # existing one alone — it's harmless — but don't re-add it.
  } >> "$ENV_FILE"
  chmod 600 "$ENV_FILE"
  say "[migrate] appended runtime-override exports to $ENV_FILE"
}

# End-to-end smoke test: invoke `bun --preload <override>` against a
# tiny script that requires the gbrain SDK and inspects whether
# Messages.prototype.create has been wrapped by our preload. This catches
# both SDK-shape drift AND any future change in how Bun loads --preload.
# Returns 0 on success.
smoke_test_preload() {
  local src="$1"
  [ -z "$src" ] && return 0
  if ! command -v bun >/dev/null 2>&1; then
    say "[migrate] bun not on PATH; skipping smoke test"
    return 0
  fi
  if [ ! -f "$PRELOAD_FILE" ]; then
    err "[migrate] preload file missing: $PRELOAD_FILE"
    return 1
  fi
  local out
  out="$(GBRAIN_SOURCE_DIR="$src" \
         GBRAIN_EXPANSION_MODEL=__patchkit_smoke__ \
         bun --preload "$PRELOAD_FILE" -e '
    const path = require("path");
    const Module = require("module");
    const r = Module.createRequire(path.join(process.env.GBRAIN_SOURCE_DIR, "package.json"));
    const M = r("@anthropic-ai/sdk/resources/messages.js").Messages;
    // Replace inner orig with a body-recording stub so we can observe what swap() returned.
    // The wrapper installed by the preload calls orig.call(this, swap(body)).
    // We probe by reading the wrapped function source: a wrapped function contains "swap".
    const wrapped = M.prototype.create.toString().includes("swap(body)");
    console.log(wrapped ? "wrapped" : "unwrapped");
  ' 2>&1)"
  case "$out" in
    wrapped)
      say "[migrate] ✓ runtime override engages under \`bun --preload\`"
      return 0 ;;
    unwrapped)
      err "[migrate] ✗ preload ran but did NOT wrap Messages.create"
      err "          The SDK shape may have drifted. Inspect: $PRELOAD_FILE"
      return 1 ;;
    *)
      err "[migrate] ✗ smoke test returned unexpected output:"
      err "$out"
      return 1 ;;
  esac
}

# Detect the bun-link cli.ts mode-flip and offer to fix it once via
# git update-index. Strictly opt-in (default Y but plainly explained).
# This is the one place patchkit will touch ~/gbrain — only with consent.
offer_clits_fix() {
  local src="$1"
  [ -z "$src" ] && return 0
  [ ! -f "$src/src/cli.ts" ] && return 0
  if ! command -v git >/dev/null 2>&1 || [ ! -d "$src/.git" ]; then return 0; fi

  local porcelain
  porcelain="$(git -C "$src" status --porcelain src/cli.ts 2>/dev/null || true)"
  [ -z "$porcelain" ] && return 0

  # Only offer if the diff is mode-only (no content change). `git diff
  # --summary` prints a "mode change" line for mode-only edits.
  local summary
  summary="$(git -C "$src" diff --summary -- src/cli.ts 2>/dev/null || true)"
  case "$summary" in
    *"mode change"*) ;;
    *) return 0 ;;
  esac

  info ""
  info "[migrate] ~/gbrain/src/cli.ts has a mode-only diff (100644 → 100755)."
  info "          This is Bun re-chmod'ing shebang files on every \`bun link\` —"
  info "          not patchkit. It's the remaining reason \`git pull\` aborts."
  info ""
  info "          One-time fix: mark cli.ts executable in the gbrain index"
  info "          (\`git -C $src update-index --chmod=+x src/cli.ts\`)."
  info "          This DOES touch ~/gbrain. Decline if you want to keep the"
  info "          tree pristine and stash/reset cli.ts manually before pulls."
  info ""
  local ans=""
  prompt "Apply the cli.ts mode fix now? [y/N]" "N" ans
  case "$ans" in
    y|Y|yes|Yes|YES)
      if git -C "$src" update-index --chmod=+x src/cli.ts 2>/dev/null; then
        info "[migrate] ✓ marked src/cli.ts executable in the gbrain index"
        info "[migrate]   git -C $src status now shows it staged; commit it from"
        info "[migrate]   your gbrain checkout, or revert with: git -C $src restore --staged src/cli.ts"
      else
        err  "[migrate] ✗ git update-index failed; skipping"
      fi
      ;;
    *)
      info "[migrate] skipped cli.ts fix (you can re-run \`gbrain-patchkit migrate\` any time)"
      ;;
  esac
}

detect_existing_auth() {
  # Populates globals:
  #   DET_OPENAI_SET (0|1) + DET_OPENAI_MASKED
  #   DET_ANTHROPIC_SET (0|1) + DET_ANTHROPIC_MASKED + DET_ANTHROPIC_BASE
  #   DET_OPENCLAW_PRESENT (0|1) + DET_OPENCLAW_GATEWAY_PORT
  #   DET_OPENCLAW_GATEWAY_TOKEN_SET (0|1)
  #   DET_OPENCLAW_MINIMAX_MODE (oauth|apikey|"")
  #   OC_MODELS[]       — TAB-separated rows: key<TAB>usable(yes|no|cli)<TAB>provider<TAB>baseUrl
  DET_OPENAI_SET=0; DET_OPENAI_MASKED=""
  DET_ANTHROPIC_SET=0; DET_ANTHROPIC_MASKED=""; DET_ANTHROPIC_BASE=""
  DET_OPENCLAW_PRESENT=0; DET_OPENCLAW_GATEWAY_PORT=""
  DET_OPENCLAW_GATEWAY_TOKEN_SET=0; DET_OPENCLAW_MINIMAX_MODE=""
  OC_MODELS=()

  if [ -n "${OPENAI_API_KEY:-}" ]; then
    DET_OPENAI_SET=1; DET_OPENAI_MASKED="$(mask "$OPENAI_API_KEY")"
  fi
  if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
    DET_ANTHROPIC_SET=1; DET_ANTHROPIC_MASKED="$(mask "$ANTHROPIC_API_KEY")"
    DET_ANTHROPIC_BASE="${ANTHROPIC_BASE_URL:-}"
  fi
  if [ -n "${OPENCLAW_GATEWAY_TOKEN:-}" ]; then
    DET_OPENCLAW_GATEWAY_TOKEN_SET=1
  fi

  local cfg="$HOME/.openclaw/openclaw.json"
  if [ -f "$cfg" ]; then
    DET_OPENCLAW_PRESENT=1
    DET_OPENCLAW_GATEWAY_PORT="$(python3 -c "
import json,sys
try:
    d=json.load(open(sys.argv[1]))
    print(d.get('gateway',{}).get('port','') or '')
except Exception:
    pass
" "$cfg" 2>/dev/null || true)"
    DET_OPENCLAW_MINIMAX_MODE="$(python3 -c "
import json,sys
try:
    d=json.load(open(sys.argv[1]))
    p=d.get('auth',{}).get('profiles',{}).get('minimax-portal:default',{})
    print(p.get('mode','') or '')
except Exception:
    pass
" "$cfg" 2>/dev/null || true)"
    # Extract model registry + classify by gbrain usability
    while IFS= read -r line; do
      [ -z "$line" ] && continue
      OC_MODELS+=("$line")
    done < <(python3 - "$cfg" <<'PY'
import json, sys
try:
    d = json.load(open(sys.argv[1]))
except Exception:
    sys.exit(0)
models = d.get('agents', {}).get('defaults', {}).get('models', {})
providers = d.get('models', {}).get('providers', {})
for key in sorted(models.keys()):
    prov = key.split('/', 1)[0] if '/' in key else key
    pcfg = providers.get(prov, {})
    api = pcfg.get('api', '') or ''
    base = pcfg.get('baseUrl', '') or ''
    if api == 'anthropic-messages' or prov == 'anthropic':
        usable = 'yes'
    elif prov == 'claude-cli':
        usable = 'cli'
    else:
        usable = 'no'
    # TAB-separated: key\tusable\tprovider\tbaseUrl
    print(f"{key}\t{usable}\t{prov}\t{base}")
PY
)
  fi
}

# Pick a model from OC_MODELS (or fall back to a plain prompt).
# Args:
#   $1 = prompt label (e.g. "Query-expansion model")
#   $2 = variable name to set with the chosen model
#   $3 = "keep-prefix" or "strip-prefix" (controls whether we emit
#        "minimax-portal/MiniMax-M2.7" vs just "MiniMax-M2.7")
#   $4 = fallback default if no models detected
pick_model() {
  local label="$1" var="$2" prefix_mode="$3" fallback="$4"
  local picked=""
  if [ "${#OC_MODELS[@]}" -eq 0 ]; then
    prompt "$label" "$fallback" picked
    printf -v "$var" '%s' "$picked"
    return
  fi

  info "  Available models (from OpenClaw config):"
  local idx=1 default_idx=0
  for row in "${OC_MODELS[@]}"; do
    IFS=$'\t' read -r key usable provider base <<< "$row"
    local tag
    case "$usable" in
      yes) tag="[ok] " ;;
      cli) tag="[cli]"; ;;
      no)  tag="[?]  " ;;
    esac
    info "    [$idx] $tag $key"
    if [ "$usable" = "yes" ] && [ "$default_idx" = "0" ]; then default_idx=$idx; fi
    idx=$((idx+1))
  done
  info "    [t]       type your own model name"
  info "    legend: [ok] usable from gbrain   [cli] requires Claude CLI subscription (gbrain can't call)   [?] non-Anthropic API"
  [ "$default_idx" = "0" ] && default_idx=1

  local pick=""
  prompt "$label (number or 't')" "$default_idx" pick
  if [ "$pick" = "t" ] || [ "$pick" = "T" ]; then
    prompt "  Model name" "$fallback" picked
  else
    local row="${OC_MODELS[$((pick-1))]:-}"
    if [ -z "$row" ]; then
      picked="$fallback"
    else
      IFS=$'\t' read -r key usable provider base <<< "$row"
      if [ "$prefix_mode" = "strip-prefix" ] && [[ "$key" == */* ]]; then
        picked="${key#*/}"
      else
        picked="$key"
      fi
      if [ "$usable" = "cli" ]; then
        info "  Warning: $key requires the Claude CLI subscription backend, not HTTP."
        info "  gbrain calls via the Anthropic SDK and will not be able to reach this model."
      elif [ "$usable" = "no" ]; then
        info "  Warning: $key provider is not marked anthropic-messages-compatible."
        info "  If it fails at call time, flip back to 'paste-key' in Step 3 or pick another."
      fi
    fi
  fi
  printf -v "$var" '%s' "$picked"
}

verify_openai() {
  local key="$1"
  [ -z "$key" ] && return 0
  if ! command -v curl >/dev/null 2>&1; then return 0; fi
  local status
  status="$(curl -sS -o /dev/null -w '%{http_code}' \
    -H "Authorization: Bearer $key" \
    -H "Content-Type: application/json" \
    --data '{"model":"text-embedding-3-large","input":"ping"}' \
    https://api.openai.com/v1/embeddings 2>/dev/null || true)"
  case "$status" in
    200) info "  ✓ OpenAI key works for embeddings" ;;
    401) info "  ✗ OpenAI key rejected (401 Unauthorized). Check for typos or revoked keys." ;;
    403) info "  ✗ OpenAI key scoped too narrowly (403). Make sure Embeddings: Request is enabled." ;;
    000) info "  ? OpenAI reachability check failed (network). Skipping." ;;
    *)   info "  ? OpenAI probe returned HTTP $status. Not fatal, but unexpected." ;;
  esac
}

# --- commands ----------------------------------------------------------------

cmd_apply() {
  ensure_config
  local src; src="$(resolve_gbrain_src)"
  run_engine apply "$src" "$CONFIG" "$LOG" "$QUIET"
}
cmd_check() {
  ensure_config
  local src; src="$(resolve_gbrain_src)"
  run_engine check "$src" "$CONFIG" "$LOG" "0"
}
cmd_revert() {
  ensure_config
  local src; src="$(resolve_gbrain_src)"
  run_engine revert "$src" "$CONFIG" "$LOG" "$QUIET"
}
cmd_edit()    { ensure_config; "${EDITOR:-open -t}" "$CONFIG"; }
cmd_env_cmd() { touch "$ENV_FILE"; chmod 600 "$ENV_FILE"; "${EDITOR:-open -t}" "$ENV_FILE"; }
cmd_locate()  { resolve_gbrain_src; }

cmd_update() {
  if [ ! -d "$PATCHKIT_HOME/.git" ]; then
    err "not a git clone. Re-run the curl installer to update."
    exit 1
  fi
  git -C "$PATCHKIT_HOME" pull --ff-only
}

# Upgrade the user's gbrain checkout end-to-end: stash → git pull → bun install →
# stash pop → gbrain post-upgrade. The stash dance handles bun-link's cli.ts mode
# flip transparently so the user never has to touch ~/gbrain themselves.
cmd_upgrade() {
  # Don't suppress stderr — if GBRAIN_SOURCE_DIR is set wrong, the user needs
  # to see exactly why resolve_gbrain_src rejected it.
  local src
  if ! src="$(resolve_gbrain_src)"; then
    err "[upgrade] could not resolve gbrain source dir; set GBRAIN_SOURCE_DIR or install gbrain"
    exit 1
  fi
  if [ ! -d "$src/.git" ]; then
    err "[upgrade] $src is not a git checkout. Use \`bun update gbrain\` for non-git installs."
    exit 1
  fi
  if ! command -v git >/dev/null 2>&1; then
    err "[upgrade] git not on PATH"; exit 1
  fi

  info "[upgrade] gbrain source: $src"

  # 1. Stash any working-tree dirt (mode-flips, half-applied patches, anything).
  local stashed=0
  local stash_msg="gbrain-patchkit-upgrade-$(date +%s)"
  if [ -n "$(git -C "$src" status --porcelain)" ]; then
    info "[upgrade] working tree dirty — stashing before pull (label: $stash_msg)"
    if git -C "$src" stash push --include-untracked --quiet -m "$stash_msg"; then
      stashed=1
    else
      err "[upgrade] git stash failed; aborting"
      exit 1
    fi
  else
    info "[upgrade] working tree clean"
  fi

  # 2. Pull (ff-only — refuse to auto-merge divergent histories).
  info "[upgrade] git pull --ff-only origin master"
  if ! git -C "$src" pull --ff-only origin master; then
    err "[upgrade] git pull failed."
    if [ "$stashed" = "1" ]; then
      err "[upgrade]   your stashed changes are at: stash@{0} ($stash_msg)"
      err "[upgrade]   restore with: git -C $src stash pop"
    fi
    exit 1
  fi

  # 3. Bun install (re-flips cli.ts mode bit; pulls any new deps).
  info "[upgrade] bun install"
  if ! (cd "$src" && bun install); then
    err "[upgrade] bun install failed; continuing (you may need to fix manually)"
  fi

  # 4. Pop the stash. cli.ts mode-flip stashes typically pop cleanly because
  #    the working tree (after bun install) already matches the stashed mode.
  #    Real conflicts mean the user had non-trivial dirt — leave it stashed.
  if [ "$stashed" = "1" ]; then
    info "[upgrade] restoring stash"
    if git -C "$src" stash pop --quiet 2>/dev/null; then
      info "[upgrade] ✓ stash restored cleanly"
    else
      # Pop failed (conflict) OR succeeded but reported nothing-to-do.
      # Check if the stash is still in the list — if so, conflict.
      if git -C "$src" stash list 2>/dev/null | grep -qF "$stash_msg"; then
        err "[upgrade] ⚠ stash pop hit a conflict; your changes are still in:"
        err "[upgrade]   git -C $src stash list   # search for $stash_msg"
        err "[upgrade]   Resolve manually with: git -C $src stash pop"
      else
        info "[upgrade] ✓ stash absorbed (no-op pop — bun install already restored the state)"
      fi
    fi
  fi

  # 5. Run gbrain post-upgrade so migrations + features refresh land.
  info "[upgrade] gbrain post-upgrade"
  if command -v gbrain >/dev/null 2>&1; then
    # Source env.sh so post-upgrade has the user's keys + GBRAIN_SOURCE_DIR.
    if [ -f "$ENV_FILE" ]; then
      # shellcheck disable=SC1090
      ( . "$ENV_FILE" && gbrain post-upgrade ) || info "[upgrade] gbrain post-upgrade returned non-zero (non-fatal)"
    else
      gbrain post-upgrade || info "[upgrade] gbrain post-upgrade returned non-zero (non-fatal)"
    fi
  else
    info "[upgrade] gbrain not on PATH; skipping post-upgrade"
  fi

  info ""
  info "[upgrade] ✓ done. cd $src && git status   # should be clean (modulo cli.ts mode if you declined the migrate fix)"
}

cmd_install() {
  ensure_config
  install_shell_hook
  : > "$LOG" 2>/dev/null || true
  say
  say "Config seeded and shell hook installed."
  say "For interactive setup of keys + models, run:  gbrain-patchkit onboard"
}

cmd_uninstall() {
  remove_shell_hook
  info ""
  info "Hook removed. Your env file, config, and install dir are still at:"
  info "  $ENV_FILE"
  info "  $CONFIG"
  info "  $PATCHKIT_HOME"
  info "Delete them manually if you want a clean wipe:  rm -rf $PATCHKIT_HOME"
}

cmd_doctor() {
  info "[doctor] tool home:       $PATCHKIT_HOME"
  info "[doctor] config:          $([ -f "$CONFIG" ] && echo present || echo MISSING)"
  info "[doctor] env file:        $([ -f "$ENV_FILE" ] && echo present || echo MISSING)"
  info "[doctor] preload file:    $([ -f "$PRELOAD_FILE" ] && echo present || echo MISSING)"
  # Source env file locally for the probe if it exists
  if [ -f "$ENV_FILE" ]; then
    # shellcheck disable=SC1090
    . "$ENV_FILE"
  fi
  local vars=(OPENAI_API_KEY ANTHROPIC_API_KEY ANTHROPIC_BASE_URL GBRAIN_EXPANSION_MODEL GBRAIN_SUBAGENT_MODEL GBRAIN_SOURCE_DIR GBRAIN_ENTRY GBRAIN_OVERRIDE_JS)
  for v in "${vars[@]}"; do
    local val="${!v-}"
    if [ -z "$val" ]; then
      printf '  %-26s (unset)\n' "$v"
    elif [[ "$v" == *_API_KEY ]]; then
      printf '  %-26s %s\n' "$v" "$(mask "$val")"
    else
      printf '  %-26s %s\n' "$v" "$val"
    fi
  done
  info ""
  if command -v gbrain >/dev/null 2>&1; then
    info "[doctor] gbrain on PATH:  $(command -v gbrain)"
  else
    info "[doctor] gbrain on PATH:  (not found)"
  fi
  info ""

  # Runtime-override smoke test — replaces the old marker-based drift check
  # for the default model substitutions.
  info "[doctor] runtime override:"
  local src=""
  if src="$(resolve_gbrain_src 2>/dev/null)"; then
    if smoke_test_preload "$src"; then
      info "  ✓ SDK present, Messages.prototype.create resolved"
    fi
  else
    info "  (gbrain source not located — can't probe SDK shape)"
  fi
  info ""

  info "[doctor] source-patch substitutions (legacy mechanism — disabled by default):"
  cmd_check || true
}

cmd_migrate() {
  ensure_config
  info ""
  info "=================================================================="
  info "  gbrain-patchkit migrate — switch to runtime SDK override"
  info "=================================================================="
  info ""
  info "  Retires source-patch mechanism for the default model substitutions."
  info "  Reverts any active patches in ~/gbrain, disables the defaults in"
  info "  substitutions.json, and wires BUN_PRELOAD into env.sh so the"
  info "  Anthropic SDK is patched in-process at every gbrain call."
  info ""

  local src=""
  if src="$(resolve_gbrain_src 2>/dev/null)"; then
    info "[migrate] gbrain source: $src"
  else
    info "[migrate] gbrain source not located (set GBRAIN_SOURCE_DIR to override)"
    info "[migrate]   skipping source-patch revert; env + preload setup will still run"
  fi
  info ""

  # 1. Revert any active source patches. Idempotent: unpatched files are skipped.
  if [ -n "$src" ]; then
    info "[migrate] reverting any active source patches"
    run_engine revert "$src" "$CONFIG" "$LOG" "0" || true
    info ""
  fi

  # 2. Disable the two default substitutions in user's config (preserves
  #    any custom substitutions the user added).
  python3 - "$CONFIG" <<'PY'
import json, pathlib, sys
p = pathlib.Path(sys.argv[1])
try:
    cfg = json.loads(p.read_text())
except Exception as e:
    print(f"[migrate] could not parse {p}: {e}", file=sys.stderr); sys.exit(0)
DEFAULT_MARKERS = {"GBRAIN_EXPANSION_MODEL", "GBRAIN_SUBAGENT_MODEL"}
changed = False
for s in cfg.get("substitutions", []):
    if s.get("marker") in DEFAULT_MARKERS and s.get("enabled", True):
        s["enabled"] = False
        s["disabled_by"] = "runtime-override"
        changed = True
if changed:
    p.write_text(json.dumps(cfg, indent=2) + "\n")
    print(f"[migrate] disabled default source substitutions in {p}")
else:
    print(f"[migrate] default substitutions already disabled in {p}")
PY
  info ""

  # 3. Make sure the preload file is present in the install dir.
  if [ ! -f "$PRELOAD_FILE" ]; then
    err "[migrate] preload file missing: $PRELOAD_FILE"
    err "[migrate]   run \`gbrain-patchkit update\` to pull it in, then re-run migrate"
    exit 1
  fi

  # 4. Append BUN_PRELOAD + GBRAIN_SOURCE_DIR exports to env.sh (idempotent).
  ensure_preload_export "$src"
  info ""

  # 5. Refresh shell hook (idempotent — bumps if version sentinel drifted).
  install_shell_hook
  info ""

  # 6. SDK shape smoke test.
  if [ -n "$src" ]; then
    smoke_test_preload "$src" || true
    info ""
  fi

  # 7. Optional cli.ts mode-flip fix (consent prompt, default N).
  offer_clits_fix "$src"

  info ""
  info "=================================================================="
  info "  Migration complete."
  info "=================================================================="
  info ""
  info "  Open a new shell or run:  exec \$SHELL -l"
  info "  Then verify:              gbrain-patchkit doctor"
  info ""
  info "  Your next \`cd ~/gbrain && git pull origin master && bun install\`"
  info "  should run without conflict (modulo the cli.ts mode bit if you"
  info "  declined the fix above)."
  info ""
}

cmd_onboard() {
  local reconfigure=0
  for f in "${FLAGS[@]:-}"; do
    [ "$f" = "--reconfigure" ] && reconfigure=1
  done

  info ""
  info "=================================================================="
  info "  gbrain-patchkit onboarding"
  info "=================================================================="
  info ""
  info "This wizard will:"
  info "  1. Locate your gbrain install"
  info "  2. Collect API keys (OpenAI for embeddings; MiniMax/etc for LLM)"
  info "  3. Collect an Anthropic-compatible base URL + model names"
  info "  4. Write env file (with BUN_PRELOAD pointing at the runtime override)"
  info "  5. Install the shell hook + verify the SDK shape"
  info "  6. Verify everything"
  info ""
  info "  NOTE: gbrain-patchkit no longer modifies ~/gbrain source files for"
  info "  the model substitutions. anthropic-override.js (a Bun preload) does"
  info "  the swap at SDK call time, so \`git pull\` in ~/gbrain just works."
  info ""
  info "All keys are stored in $ENV_FILE with 600 perms. Nothing leaves your machine."
  info ""

  # --- Step 1: locate gbrain ---
  info "Step 1/6  Locate gbrain"
  local src=""
  if src="$(resolve_gbrain_src 2>/dev/null)"; then
    info "  ✓ Found gbrain source at: $src"
  else
    info "  ✗ gbrain not found on PATH."
    info "    Install it first:  bun install -g github:garrytan/gbrain"
    info "    Or export GBRAIN_SOURCE_DIR=/path/to/your/gbrain checkout and re-run onboard."
    exit 1
  fi
  info ""

  # --- Detect existing auth on this machine ---
  detect_existing_auth

  # --- Step 2: OpenAI key ---
  info "Step 2/6  OpenAI API key (for embeddings — required for vector search)"
  local openai=""
  if [ "$DET_OPENAI_SET" = "1" ]; then
    info "  [detected] OPENAI_API_KEY already set in your environment: $DET_OPENAI_MASKED"
    local reuse=""
    prompt "Reuse it? [Y/n]" "Y" reuse
    case "$reuse" in
      n|N|no|No|NO)
        prompt_secret "Paste a new OpenAI key (sk-...) or leave blank to skip" openai ;;
      *)
        openai="$OPENAI_API_KEY"
        info "  ✓ keeping $DET_OPENAI_MASKED" ;;
    esac
  else
    info "  Create a RESTRICTED key with only 'Embeddings: Request' enabled:"
    info "    https://platform.openai.com/api-keys"
    info "  Leave blank to skip (gbrain falls back to keyword-only search)."
    prompt_secret "OpenAI API key (sk-...)" openai
    [ -n "$openai" ] && info "    got: $(mask "$openai")"
  fi
  info ""

  # --- Step 3: LLM credential (MiniMax / Anthropic-compat) with auth detection ---
  info "Step 3/6  LLM API credential (query expansion + \`gbrain agent run\`)"
  info ""
  info "  Auth scan:"
  if [ "$DET_ANTHROPIC_SET" = "1" ]; then
    info "    ✓ ANTHROPIC_API_KEY already set ($DET_ANTHROPIC_MASKED)"
    [ -n "$DET_ANTHROPIC_BASE" ] && info "      with ANTHROPIC_BASE_URL=$DET_ANTHROPIC_BASE"
  fi
  if [ "$DET_OPENCLAW_PRESENT" = "1" ]; then
    info "    ✓ OpenClaw config at ~/.openclaw/openclaw.json"
    [ -n "$DET_OPENCLAW_GATEWAY_PORT" ] && info "      gateway on loopback:$DET_OPENCLAW_GATEWAY_PORT"
    [ "$DET_OPENCLAW_GATEWAY_TOKEN_SET" = "1" ] && info "      OPENCLAW_GATEWAY_TOKEN is set"
    if [ "$DET_OPENCLAW_MINIMAX_MODE" = "oauth" ]; then
      info "      minimax-portal auth = oauth (NOTE: OAuth tokens are NOT portable to gbrain)"
    fi
  fi
  if [ "$DET_ANTHROPIC_SET" = "0" ] && [ "$DET_OPENCLAW_PRESENT" = "0" ]; then
    info "    (no existing LLM auth detected on this machine)"
  fi
  info ""

  # Build menu of choices
  local choices=()
  local default_choice=""
  if [ "$DET_ANTHROPIC_SET" = "1" ]; then
    choices+=("reuse-anthropic"); default_choice="${default_choice:-reuse-anthropic}"
  fi
  if [ "$DET_OPENCLAW_GATEWAY_TOKEN_SET" = "1" ] && [ -n "$DET_OPENCLAW_GATEWAY_PORT" ]; then
    choices+=("openclaw-gateway"); default_choice="${default_choice:-openclaw-gateway}"
  fi
  choices+=("paste-key")
  choices+=("skip")
  default_choice="${default_choice:-paste-key}"

  info "  Pick credential source:"
  local idx=1 default_idx=0
  for c in "${choices[@]}"; do
    case "$c" in
      reuse-anthropic)  info "    [$idx] Reuse \$ANTHROPIC_API_KEY ($DET_ANTHROPIC_MASKED)" ;;
      openclaw-gateway) info "    [$idx] Route through OpenClaw gateway 127.0.0.1:$DET_OPENCLAW_GATEWAY_PORT using \$OPENCLAW_GATEWAY_TOKEN" ;;
      paste-key)        info "    [$idx] Paste a static API key (MiniMax platform, direct Anthropic, etc.)" ;;
      skip)             info "    [$idx] Skip (query expansion + agent disabled; search still works)" ;;
    esac
    [ "$c" = "$default_choice" ] && default_idx=$idx
    idx=$((idx+1))
  done

  local picked=""
  prompt "Choice" "$default_idx" picked
  local choice="${choices[$((picked-1))]:-$default_choice}"
  info ""

  local minimax="" minimax_base="" exp_model="" sub_model=""
  case "$choice" in
    reuse-anthropic)
      minimax="$ANTHROPIC_API_KEY"
      info "  ✓ reusing \$ANTHROPIC_API_KEY"
      if [ -n "$DET_ANTHROPIC_BASE" ]; then
        local keep=""
        prompt "Keep existing ANTHROPIC_BASE_URL=$DET_ANTHROPIC_BASE? [Y/n]" "Y" keep
        case "$keep" in
          n|N|no|No|NO) prompt "New Anthropic-compatible base URL (blank for Anthropic default)" "" minimax_base ;;
          *)            minimax_base="$DET_ANTHROPIC_BASE" ;;
        esac
      else
        prompt "Anthropic-compatible base URL (blank = Anthropic default)" "" minimax_base
      fi
      ;;
    openclaw-gateway)
      info "  Using OPENCLAW_GATEWAY_TOKEN as the Anthropic API key."
      info "  You need the gateway path that exposes an Anthropic-compatible surface."
      info "  Check your OpenClaw docs — the full URL typically looks like"
      info "    http://127.0.0.1:$DET_OPENCLAW_GATEWAY_PORT/<some-path>"
      info ""
      minimax="$OPENCLAW_GATEWAY_TOKEN"
      prompt "Gateway Anthropic-compat URL" "http://127.0.0.1:$DET_OPENCLAW_GATEWAY_PORT/anthropic" minimax_base
      ;;
    paste-key)
      info "  For MiniMax direct: create an API key at the MiniMax platform console."
      info "  Leave blank to skip."
      prompt_secret "API key" minimax
      if [ -n "$minimax" ]; then
        info "    got: $(mask "$minimax")"
        info "  MiniMax default (verify in their docs): https://api.minimaxi.chat/anthropic"
        prompt "Anthropic-compatible base URL" "https://api.minimaxi.chat/anthropic" minimax_base
      fi
      ;;
    skip)
      info "  Skipping LLM credential."
      ;;
  esac
  info ""

  # --- Step 4: model names (only if we have an LLM key) ---
  if [ -n "$minimax" ]; then
    info "Step 4/6  Model names"
    # When routing through the OpenClaw gateway, the gateway expects
    # "provider/model" (that's how it maps to the upstream provider).
    # For direct provider endpoints (MiniMax/Anthropic), strip the prefix.
    local prefix_mode="strip-prefix"
    [ "$choice" = "openclaw-gateway" ] && prefix_mode="keep-prefix"

    info "  Query-expansion model — replaces hardcoded Claude Haiku."
    info "  Keep fast + tool-use-capable; this fires on every search ≥3 words."
    pick_model "Pick for query-expansion" exp_model "$prefix_mode" "MiniMax-M2.7-highspeed"
    info "  → exp_model = $exp_model"
    info ""

    info "  Subagent default — replaces hardcoded Claude Sonnet."
    info "  Used by \`gbrain agent run\` when no --model flag is given."
    info "  Pick a fuller-capability model here; speed matters less."
    pick_model "Pick for subagent default" sub_model "$prefix_mode" "MiniMax-M2.7"
    info "  → sub_model = $sub_model"
  else
    info "Step 4/6  (skipped — no LLM credential provided)"
  fi
  info ""

  # --- Step 5: write files + install hook + smoke-test the runtime override ---
  info "Step 5/6  Write env + install shell hook + verify runtime override"
  write_env_file "$openai" "$minimax" "$minimax_base" "$exp_model" "$sub_model"
  info "  ✓ wrote $ENV_FILE (includes BUN_PRELOAD for runtime override)"
  install_shell_hook
  ensure_config
  # shellcheck disable=SC1090
  . "$ENV_FILE"
  # Verify the Anthropic SDK is at the path our preload hooks. No source
  # patches are applied — the preload does the swap at call time.
  smoke_test_preload "$src" || true
  info ""

  # --- Step 6: verify ---
  info "Step 6/6  Verify"
  [ -n "$openai" ] && verify_openai "$openai"
  info ""

  # --- Done ---
  info "=================================================================="
  info "  Setup complete."
  info "=================================================================="
  info ""
  info "Your keys live in $ENV_FILE and are scoped to the \`gbrain\` command."
  info "They will NOT leak into Claude Code, codex, or other Anthropic-SDK tools"
  info "running in the same shell."
  info ""
  info "Reload your shell to pick up the hook (open a new terminal, or run):"
  info "  exec \$SHELL -l"
  info ""
  info "If this is an upgrade from an older hook that sourced keys globally,"
  info "already-open shells still have ANTHROPIC_API_KEY / ANTHROPIC_BASE_URL"
  info "in their env. Either reload those shells as above, or run:"
  info "  unset ANTHROPIC_API_KEY ANTHROPIC_BASE_URL"
  info ""
  info "Then try:"
  info "  gbrain doctor"
  info "  gbrain search \"your query at least three words\""
  info ""
  info "Other useful commands:"
  info "  gbrain-patchkit doctor       verify env + preload + patch state"
  info "  gbrain-patchkit migrate      switch existing source-patch installs to runtime override"
  info "  gbrain-patchkit env          edit your keys / models"
  info "  gbrain-patchkit edit         edit substitutions.json (custom source patches)"
  info "  gbrain-patchkit check        show source-patch status (legacy)"
  info "  gbrain-patchkit revert       undo source patches (legacy)"
  info "  gbrain-patchkit uninstall    remove shell hook"
  info ""
}

cmd_help() {
  # Print the leading comment block: lines starting at the first non-shebang
  # comment, stopping at the first blank or non-comment line.
  awk 'NR==1 && /^#!/ {next}
       /^#/ {sub(/^# ?/,""); print; next}
       {exit}' "$0"
}

main() {
  local cmd="${FLAGS[0]:-help}"
  case "$cmd" in
    onboard)   cmd_onboard ;;
    install)   cmd_install ;;
    migrate)   cmd_migrate ;;
    upgrade)   cmd_upgrade ;;
    apply)     cmd_apply ;;
    check)     cmd_check ;;
    revert)    cmd_revert ;;
    doctor)    cmd_doctor ;;
    edit)      cmd_edit ;;
    env)       cmd_env_cmd ;;
    locate)    cmd_locate ;;
    update)    cmd_update ;;
    uninstall) cmd_uninstall ;;
    help|-h|--help) cmd_help ;;
    *) err "unknown command: $cmd"; cmd_help; exit 2 ;;
  esac
}

main
